# SpikeGuard .gitignore

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Data & models (download at runtime)
data/cifar10/
data/wildlife/
checkpoints/
models/*.onnx
models/*.pt
*.pt
*.onnx

# Logs
runs/
*.log
*.json

# OS
.DS_Store
Thumbs.db
desktop.ini

# Jupyter
.ipynb_checkpoints/

# Presentation docs (keep locally, don't publish)
docs/video_script.md
docs/pitch_deck.md

# Temp
/tmp/
*.tmp
